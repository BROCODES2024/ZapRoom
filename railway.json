{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": "echo 'This is a monorepo. Please check backend and frontend folders.'",
    "restartPolicyType": "never"
  },
  "services": {
    "backend": {
      "pipeline": [
        {
          "type": "repo",
          "config": {
            "rootDirectory": "/backend"
          }
        }
      ]
    },
    "frontend": {
      "pipeline": [
        {
          "type": "repo",
          "config": {
            "rootDirectory": "/frontend"
          }
        }
      ]
    }
  }
}
